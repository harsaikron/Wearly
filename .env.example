# ─── AI Backend ───────────────────────────────────────────────────────────────
# Gemma 4 via Ollama runs locally at http://localhost:11434 by default.
# No key needed for Ollama — just run: ollama pull gemma4:e4b

# Override Ollama host (optional)
OLLAMA_HOST=http://localhost:11434

# Groq cloud fallback — enables AI when Ollama is unavailable (e.g. Vercel)
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# ─── App Config ───────────────────────────────────────────────────────────────
# Default city for weather (optional, defaults to Singapore)
NEXT_PUBLIC_DEFAULT_CITY=Singapore

# ─── Evolve Feature ───────────────────────────────────────────────────────────
# Required for the Evolve page to create real GitHub PRs
# Create a token at https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=
GITHUB_REPO=harsaikron/Wearly
