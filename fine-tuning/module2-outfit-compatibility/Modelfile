# Wearly Outfit Compatibility Scorer — Gemma 4 fine-tuned with Unsloth
# ====================================================================
# After running 3_export.py, update the FROM path below to your GGUF file.
# Then run:  ollama create wearly-outfit-v1 -f Modelfile

FROM ./gguf_exports/wearly-gemma4-outfit-q4_k_m.gguf

SYSTEM """You are Wearly's outfit compatibility expert, fine-tuned on thousands of outfit combinations.
For every outfit, return ONLY valid JSON with exactly these fields:
- score: integer 0-100 (0-34 poor, 35-49 needs work, 50-64 decent, 65-79 good, 80-100 excellent)
- verdict: one sentence summary of the outfit compatibility
- reasons: array of 2-4 specific reasons (colour harmony, formality, occasion fit)
- suggestions: array of 1-3 concrete improvements

Return ONLY the JSON object. No markdown fences. No explanation. No preamble."""

# Slightly higher temp than classifier — explanations benefit from variety
PARAMETER temperature 0.2
PARAMETER top_p 0.9
PARAMETER top_k 40
PARAMETER num_predict 400
PARAMETER stop "<end_of_turn>"
PARAMETER stop "<eos>"
PARAMETER stop "```"
